<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="portal_create_request_template" name="Create Maintenance Request">
        <t t-call="website.layout">
            <div class="container mt-4 mb-5">
                <div class="row justify-content-center">
                    <div class="col-lg-10">
                        <div class="card shadow">
                            <div class="card-header bg-primary text-white">
                                <h3 class="mb-0">New Maintenance Request Form</h3>
                            </div>
                            <div class="card-body p-4">
                                <form action="/my/requests/submit" method="post">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold">Equipment (Required)</label>
                                            <select name="equipment_id" class="form-select" required="1">
                                                <t t-foreach="equipments" t-as="eq">
                                                    <option t-att-value="eq.id"><t t-esc="eq.name"/></option>
                                                </t>
                                            </select>
                                        </div>

                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold">Responsible Person</label>
                                            <select name="user_id" class="form-select">
                                                <t t-foreach="users" t-as="u">
                                                    <option t-att-value="u.id" t-att-selected="u.id == request.env.user.id">
                                                        <t t-esc="u.name"/>
                                                    </option>
                                                </t>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold">Priority</label>
                                            <select name="priority" class="form-select">
                                                <option value="0">Low</option>
                                                <option value="1" selected="selected">Medium</option>
                                                <option value="2">High</option>
                                            </select>
                                        </div>

                                      <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Scheduled Start Date</label>
                                        <input type="datetime-local" 
                                            name="start_date" 
                                            class="form-control" 
                                            readonly="1" 
                                            t-att-value="start_date_value or ''"/>
                                    </div>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label fw-bold">Problem Description</label>
                                        <textarea name="description" class="form-control" rows="6" 
                                                placeholder="Provide a detailed description of the equipment issue..." required="1"></textarea>
                                    </div>

                                    <div class="d-flex justify-content-between border-top pt-3">
                                        <a href="/my/requests" class="btn btn-outline-secondary">Back to List</a>
                                        <button type="submit" class="btn btn-primary btn-lg px-5">Submit Maintenance Request</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>