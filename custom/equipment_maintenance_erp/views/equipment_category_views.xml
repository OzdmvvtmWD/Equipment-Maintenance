<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================= ACTION ================= -->
    <record id="action_equipment_category" model="ir.actions.act_window">
        <field name="name">Equipment Categories</field>
        <field name="res_model">equipment.category</field>
        <field name="view_mode">list,form,kanban,pivot</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No equipment category
            </p>
        </field>
    </record>

    <!-- ================= LIST VIEW ================= -->
    <record id="view_equipment_category_list" model="ir.ui.view">
        <field name="name">equipment.category.list</field>
        <field name="model">equipment.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="parent_id"/>
                <field name="equipment_count"/>
            </list>
        </field>
    </record>

    <!-- ================= FORM VIEW ================= -->
    <record id="view_equipment_category_form" model="ir.ui.view">
        <field name="name">equipment.category.form</field>
        <field name="model">equipment.category</field>
        <field name="arch" type="xml">
            <form string="Equipment Category">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="parent_id"/>
                        <field name="equipment_count" readonly="1"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================= SEARCH VIEW ================= -->
    <record id="view_equipment_category_search" model="ir.ui.view">
        <field name="name">equipment.category.search</field>
        <field name="model">equipment.category</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="parent_id"/>
                <filter string="Has Children" name="has_children" domain="[('child_ids','!=',False)]"/>
            </search>
        </field>
    </record>

    <!-- ================= KANBAN VIEW ================= -->
    <record id="view_equipment_category_kanban" model="ir.ui.view">
        <field name="name">equipment.category.kanban</field>
        <field name="model">equipment.category</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <strong><field name="name"/></strong>
                            <div>Parent: <field name="parent_id"/></div>
                            <div>Equipment Count: <field name="equipment_count"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================= PIVOT VIEW ================= -->
    <record id="view_equipment_category_pivot" model="ir.ui.view">
        <field name="name">equipment.category.pivot</field>
        <field name="model">equipment.category</field>
        <field name="arch" type="xml">
            <pivot string="Equipment Category Pivot">
                <field name="name" type="row"/>
                <field name="parent_id" type="col"/>
                <field name="equipment_count" type="measure" operator="sum"/>
            </pivot>
        </field>
    </record>

</odoo>