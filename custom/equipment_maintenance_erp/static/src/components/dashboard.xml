<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="equipment_maintenance_erp.MaintenanceDashboard" owl="1">
        <div class="o_dashboards overflow-auto bg-light h-100">
            <div class="container-fluid pt-4">
                <div class="row m-0">
                    <div class="col-md-4 mb-4">
                        <div class="card shadow-sm border-0 text-center p-3">
                            <div class="text-uppercase fw-bold text-muted small">Total Equipment</div>
                            <div class="display-4 fw-bold text-primary"><t t-esc="state.stats.total_equipment"/></div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-4">
                        <div class="card shadow-sm border-0 text-center p-3">
                            <div class="text-uppercase fw-bold text-muted small">Open Requests</div>
                            <div class="display-4 fw-bold text-warning"><t t-esc="state.stats.open_requests"/></div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-4">
                        <div class="card shadow-sm border-0 text-center p-3">
                            <div class="text-uppercase fw-bold text-muted small">Overdue</div>
                            <div class="display-4 fw-bold text-danger"><t t-esc="state.stats.overdue_requests"/></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>